// Cloudflare Workers 部署配置(纯静态资产,无 Worker 脚本)。
// CF Git 接入的部署命令 `npx wrangler deploy` 依赖本文件:
// 把 `npm run build` 产出的 out/ 作为静态资产上传;
// not_found_handling 用 out/404.html 兜底并返回真实 404 状态码。
{
  "name": "site-issacbytes",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./out",
    "not_found_handling": "404-page"
  }
}
